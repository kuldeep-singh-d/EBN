            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"member@example.com\",\n    \"password\": \"password\",\n    \"device_name\": \"postman\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
